# Copy to .env and adjust. .env is never committed (spec §12).
DATABASE_URL=postgres://minime:minime@localhost:5432/minime
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text        # 768 dims; changing model requires re-embed migration
CLASSIFY_MODEL=llama3.1:8b

# ---- LLM provider routing (default: everything local via Ollama) -------------------
# Cloud providers send tier <= CLOUD_MAX_TIER content off-box; every call is audited
# in `events` (verb egress:*) and shows up in `minime audit`. Tier 0 NEVER leaves.
# embed: ollama | openai (768-dim constraint).  classify: any provider below.
EMBED_PROVIDER=ollama
CLASSIFY_PROVIDER=ollama
CLOUD_MAX_TIER=2                    # lower to 1 to keep journal/interactions local-only
#ANTHROPIC_API_KEY=
#ANTHROPIC_MODEL=claude-opus-4-8
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4o-mini
#OPENAI_EMBED_MODEL=text-embedding-3-small
#OPENROUTER_API_KEY=
#OPENROUTER_MODEL=openai/gpt-4o-mini
#OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b   # must honor dimensions=768; run `reembed` after switching
#BEDROCK_MODEL=                     # e.g. us.anthropic.claude-opus-4-8 (list-inference-profiles)
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_REGION=
TZ=Asia/Singapore
TIER2_UNLOCK_MAX_MINUTES=60
# Local disk or cloud object storage — restic encrypts client-side either way
# (DECISIONS.md 2026-06-11). Cloud examples:
#   RESTIC_REPOSITORY=b2:minime-backup:restic        (+ B2_ACCOUNT_ID / B2_ACCOUNT_KEY)
#   RESTIC_REPOSITORY=s3:s3.amazonaws.com/minime-backup  (+ AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
RESTIC_REPOSITORY=/mnt/backup/minime-restic
RESTIC_PASSWORD_FILE=~/.config/minime/restic.pass
DREAM_CRON=0 3 * * *
