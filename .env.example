# Copy to .env and adjust. .env is never committed (spec §12).
DATABASE_URL=postgres://minime:minime@localhost:5432/minime
OLLAMA_URL=http://localhost:11434

# Optional LOCAL cross-encoder rerank stage (Phase 3; big precision lift — see
# docs/benchmarks/). Localhost only (I1) — remote URLs are refused. Fail-open: search
# works unchanged when the server is down. Serve with:
#   llama-server -m ~/models/bge-reranker-v2-m3-Q8_0.gguf --rerank --port 8114 \
#     -ub 4096 -b 4096 --parallel 4 -c 16384
#RERANK_URL=http://localhost:8114
#RERANK_MODEL=bge-reranker-v2-m3
#RERANK_TOP_IN=20
EMBED_MODEL=nomic-embed-text        # 768 dims; changing model requires re-embed migration
CLASSIFY_MODEL=llama3.1:8b

# ---- LLM provider routing -----------------------------------------------------------
# Owner's standing configuration (2026-06-12): CLASSIFY_PROVIDER=bedrock (IAM creds via
# ~/.aws or env; BEDROCK_MODEL required) and EMBED_PROVIDER=openrouter
# (qwen/qwen3-embedding-8b @ 768). Local Ollama is an OPTION/fallback, not the
# preference — benchmarks and the dream cycle should run against the standing config;
# scorecards stamp the models used.
# Cloud providers send tier <= CLOUD_MAX_TIER content off-box; every call is audited
# in `events` (verb egress:*) and shows up in `minime audit`. Tier 0 NEVER leaves.
# embed: ollama | openai | openrouter (768-dim constraint).  classify: any provider below.
EMBED_PROVIDER=ollama
CLASSIFY_PROVIDER=ollama
CLOUD_MAX_TIER=2                    # lower to 1 to keep journal/interactions local-only
#ANTHROPIC_API_KEY=
#ANTHROPIC_MODEL=claude-opus-4-8
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4o-mini
#OPENAI_EMBED_MODEL=text-embedding-3-small
#OPENROUTER_API_KEY=
#OPENROUTER_MODEL=openai/gpt-4o-mini
#OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b   # must honor dimensions=768; run `reembed` after switching
#BEDROCK_MODEL=                     # e.g. us.anthropic.claude-opus-4-8 (list-inference-profiles)
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_REGION=
TZ=Asia/Singapore
TIER2_UNLOCK_MAX_MINUTES=60
# Local disk or cloud object storage — restic encrypts client-side either way
# (DECISIONS.md 2026-06-11). Cloud examples:
#   RESTIC_REPOSITORY=b2:minime-backup:restic        (+ B2_ACCOUNT_ID / B2_ACCOUNT_KEY)
#   RESTIC_REPOSITORY=s3:s3.amazonaws.com/minime-backup  (+ AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
RESTIC_REPOSITORY=/mnt/backup/minime-restic
RESTIC_PASSWORD_FILE=~/.config/minime/restic.pass
DREAM_CRON=0 3 * * *
