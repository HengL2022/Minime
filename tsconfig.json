{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "verbatimModuleSyntax": true,
    "noEmit": true
  },
  "include": ["src", "test", "fixtures"]
}
