# secrets — never committed (spec §12)
.env
.env.*
!.env.example

# owner data — files are the archive, but not in this repo (spec §5)
data/*
!data/**/.gitkeep

# runtime
node_modules/
db-dump/
*.log
.ollama-serve.log
.DS_Store

# MinimeBench round results — never pushed to GitHub; only the committed floor
# (fixtures/qrels/baseline.ndjson) is tracked. The scorecard is regenerated each run.
eval-results/*
!eval-results/.gitkeep
