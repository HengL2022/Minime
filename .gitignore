# secrets — never committed (spec §12)
.env
.env.*
!.env.example

# owner data — files are the archive, but not in this repo (spec §5)
data/*
!data/**/.gitkeep
# stoplist template is committed docs; the live non-org-terms.txt stays local (owner-domain)
!data/non-org-terms.example.txt
# known-orgs allow-list template is committed docs; live known-orgs.txt stays local
!data/known-orgs.example.txt

# runtime
node_modules/
db-dump/
*.log
.ollama-serve.log
.DS_Store

.claude/worktrees/
